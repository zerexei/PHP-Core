{
    "name": "zeretei/php-core",
    "description": "A lightweight, zero-dependency PHP MVC micro-framework.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Angelo Arcillas",
            "email": "angeloarcillas64@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zerexei\\PHPCore\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "prefer-stable": true,
    "scripts": {
        "dev": "php -S localhost:8000 -t public",
        "test": "phpunit"
    }
}
